# ========================
# Server Configuration
# ========================
NODE_ENV=development
PORT=5000

# ========================
# Database (MongoDB)
# ========================
MONGODB_URI=mongodb://localhost:27017/lead-crm

# ========================
# JWT / Authentication
# ========================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ========================
# CORS
# ========================
CLIENT_URL=http://localhost:5173

# ========================
# Logging
# ========================
LOG_LEVEL=debug
