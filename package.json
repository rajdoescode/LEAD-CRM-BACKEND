    "express-validator": "^7.3.2",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-node": "^11.1.0",
    "globals": "^17.5.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
