{
  "name": "lead-crm-server",
  "version": "1.0.0",
  "description": "Lead CRM — Backend API Server",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon",
    "seed": "node src/scripts/seed.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,json}\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
